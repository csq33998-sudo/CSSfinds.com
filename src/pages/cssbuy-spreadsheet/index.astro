---
import ProductExplorer from "@/components/ProductExplorer.astro";
import { categories, getBreadcrumbSchema, getItemListSchema, products } from "@/data/products";
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "CSSBuy Spreadsheet 2026 - CSSBuy Finds, QC Photos and Product Links";
const description =
  "Updated CSSBuy spreadsheet-style index with categorized streetwear finds, product photos, QC-ready labels, prices, ratings, and StreetStyle shopping links.";
const schema = [
  getItemListSchema({
    items: products,
    name: "CSSBuy Spreadsheet 2026 product finds",
    url: "https://cssfinds.com/cssbuy-spreadsheet/",
  }),
  getBreadcrumbSchema([
    { name: "CSSFinds", url: "https://cssfinds.com/" },
    { name: "CSSBuy Spreadsheet", url: "https://cssfinds.com/cssbuy-spreadsheet/" },
  ]),
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <section class="shell py-10">
    <p class="text-sm font-black uppercase text-clay">Core index</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-black leading-tight tracking-normal md:text-5xl">
      CSSBuy Spreadsheet 2026
    </h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-ink/75">
      This spreadsheet page targets the broad CSSBuy spreadsheet query with a latest product collection, product images, prices, QC status, updated find dates, and clear paths into StreetStyle.
    </p>
  </section>
  <ProductExplorer products={products} />
  <section class="shell mt-8 grid gap-3 md:grid-cols-3" aria-label="CSSBuy spreadsheet category pages">
    {
      categories.map((category) => (
        <a class="button border border-line bg-white text-ink hover:border-moss" href={`/cssbuy-${category.slug}/`}>
          {category.title}
        </a>
      ))
    }
  </section>
</BaseLayout>
