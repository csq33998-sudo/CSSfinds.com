---
import { blogPosts } from "@/data/blog";
---

<section class="shell py-8 md:py-10">
  <nav class="flex flex-wrap items-center gap-2 text-sm font-bold text-ink/56" aria-label="Breadcrumb">
    <a class="transition hover:text-ink" href="/">Home</a>
    <span aria-hidden="true">/</span>
    <span class="text-ink">Blog</span>
  </nav>

  <div class="mt-8 border-b border-line pb-7">
    <p class="text-sm font-black uppercase text-clay">CSSFinds Blog</p>
    <h1 class="mt-3 text-4xl font-black leading-tight tracking-normal text-ink md:text-5xl">Blog</h1>
    <p class="mt-4 max-w-3xl text-base leading-7 text-ink/68 md:text-lg">
      Guides, shopping notes, QC checklists, and spreadsheet research updates for CSSBuy product finds.
    </p>
  </div>
</section>

<section class="shell pb-12" aria-label="CSSFinds blog posts">
  <div class="grid gap-0 rounded-lg border border-line bg-white shadow-sm">
    {blogPosts.map((post) => (
      <article class="grid gap-5 border-b border-line p-5 last:border-b-0 md:grid-cols-[1fr_240px] md:items-center md:p-6 lg:grid-cols-[1fr_300px]">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2 text-xs font-black uppercase text-ink/54">
            <time datetime={post.date}>{post.date}</time>
            <span aria-hidden="true">.</span>
            <span class="rounded-full border border-line px-3 py-1 text-ink/72">{post.category}</span>
            <span aria-hidden="true">.</span>
            <span>{post.readTime}</span>
          </div>

          <h2 class="mt-3 text-2xl font-black leading-tight tracking-normal text-ink md:text-3xl">
            <a class="transition hover:text-clay" href={post.href}>{post.title}</a>
          </h2>

          <p class="mt-3 max-w-3xl text-sm leading-6 text-ink/68 md:text-base">{post.excerpt}</p>

          <div class="mt-4 flex flex-wrap items-center gap-2">
            {post.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>

          <a class="mt-5 inline-flex text-sm font-black text-ink transition hover:text-clay" href={post.href}>
            Read more
          </a>
        </div>

        <a class="block overflow-hidden rounded-lg border border-line bg-slate-50" href={post.href} aria-label={post.title}>
          <img
            class="aspect-[4/3] w-full object-cover transition duration-200 hover:scale-[1.02]"
            src={post.image}
            alt={post.imageAlt}
            loading="lazy"
            width="600"
            height="450"
          />
        </a>
      </article>
    ))}
  </div>

  <p class="mt-8 text-center text-sm font-bold text-ink/55">More CSSBuy research notes will be added as the spreadsheet grows.</p>
</section>
